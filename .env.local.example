# ─────────────────────────────────────────────
# 242Go AHDP — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
# Get from @BotFather → /mybots → API Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── App URL ───────────────────────────────────
# Your deployed Vercel URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://telegram-mini-app-beta-coral.vercel.app

# ── Anthropic / Claude ────────────────────────
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────
# Get from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Notion ────────────────────────────────────
# Get from notion.so/my-integrations
NOTION_API_KEY=secret_...
# Jesus Generation Database ID (from Notion URL)
NOTION_DATABASE_ID=789a46b1717b40faa63d8cafcc85d000

# ── Admin ─────────────────────────────────────
# Comma-separated Telegram user IDs with admin access
# Get user IDs from @userinfobot
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Cron / Security ───────────────────────────
# Random secret for protecting cron + broadcast endpoints
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
